---
layout: base.njk
---
<main>
  <div class="page-wrap">
    <div class="page-header">
      <h1>Coverage</h1>
    </div>

    {# ── Map card ── #}
    <a href="https://swbc.meshmapper.net/?coverage-only" target="_blank" rel="noopener noreferrer" class="map-card-link">
      <div class="map-card">
        <div class="map-card-bg">
          <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg" style="position:absolute;inset:0">
            <defs>
              <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
                <path d="M 40 0 L 0 0 0 40" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.15"/>
              </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#grid)"/>
            <circle cx="52%" cy="48%" r="60" fill="none" stroke="currentColor" stroke-width="1" opacity="0.2" stroke-dasharray="6 4"/>
            <circle cx="52%" cy="48%" r="100" fill="none" stroke="currentColor" stroke-width="1" opacity="0.12" stroke-dasharray="6 4"/>
            <circle cx="52%" cy="48%" r="150" fill="none" stroke="currentColor" stroke-width="0.75" opacity="0.08" stroke-dasharray="6 4"/>
            <circle cx="52%" cy="48%" r="5" fill="currentColor" opacity="0.35"/>
            <circle cx="47%" cy="44%" r="5" fill="currentColor" opacity="0.35"/>
            <circle cx="55%" cy="42%" r="5" fill="currentColor" opacity="0.35"/>
            <circle cx="58%" cy="51%" r="5" fill="currentColor" opacity="0.35"/>
            <circle cx="49%" cy="53%" r="5" fill="currentColor" opacity="0.35"/>
            <circle cx="44%" cy="49%" r="5" fill="currentColor" opacity="0.35"/>
            <circle cx="56%" cy="55%" r="5" fill="currentColor" opacity="0.35"/>
          </svg>
        </div>
        <div class="map-card-content">
          <div class="map-card-badge">Live Coverage Map</div>
          <h3 class="map-card-title">Southwest BC — MeshMapper</h3>
          <p class="map-card-desc">Interactive wardriving coverage map for the Salish Mesh region, powered by MeshMapper.</p>
          <span class="map-card-btn">Open Coverage Map &rarr;</span>
        </div>
      </div>
    </a>

    {# ── Repeater grid ── #}
    <h2 class="section-title">Repeaters</h2>
    <a href="https://analyzer.ve7kod.ca/#/map" target="_blank" rel="noopener noreferrer" class="map-card-link">
      <div class="map-card">
        <div class="map-card-bg">
          <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg" style="position:absolute;inset:0">
            <defs>
              <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
                <path d="M 40 0 L 0 0 0 40" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.15"/>
              </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#grid)"/>
            <circle cx="52%" cy="48%" r="60" fill="none" stroke="currentColor" stroke-width="1" opacity="0.2" stroke-dasharray="6 4"/>
            <circle cx="52%" cy="48%" r="100" fill="none" stroke="currentColor" stroke-width="1" opacity="0.12" stroke-dasharray="6 4"/>
            <circle cx="52%" cy="48%" r="150" fill="none" stroke="currentColor" stroke-width="0.75" opacity="0.08" stroke-dasharray="6 4"/>
            <circle cx="52%" cy="48%" r="5" fill="currentColor" opacity="0.35"/>
            <circle cx="47%" cy="44%" r="5" fill="currentColor" opacity="0.35"/>
            <circle cx="55%" cy="42%" r="5" fill="currentColor" opacity="0.35"/>
            <circle cx="58%" cy="51%" r="5" fill="currentColor" opacity="0.35"/>
            <circle cx="49%" cy="53%" r="5" fill="currentColor" opacity="0.35"/>
            <circle cx="44%" cy="49%" r="5" fill="currentColor" opacity="0.35"/>
            <circle cx="56%" cy="55%" r="5" fill="currentColor" opacity="0.35"/>
          </svg>
        </div>
        <div class="map-card-content">
          <div class="map-card-badge">Live Node Map</div>
          <h3 class="map-card-title">VE7KOD Analyzer</h3>
          <p class="map-card-desc">Interactive network map, powered by CoreScope, provided by VE7KOD.</p>
          <span class="map-card-btn">Open Node Map &rarr;</span>
        </div>
      </div>
    </a>

    {# ── CTA ── #}
    <h2 class="section-title">Help Improve Coverage</h2>
    <div class="grid-2" style="margin-bottom:2rem">
      <div class="card" style="text-align:center;padding:2rem">
        <h3 style="margin-bottom:0.75rem">Add a Repeater</h3>
        <p style="color:var(--text-muted);margin-bottom:1.5rem">Set up a repeater on your roof or in a tree, or report areas of spotty coverage you'd like to see expanded.</p>
        <a href="#" class="btn btn-primary protected-email" data-e="vasb@fnyvfuzrfu.arg">Get in touch &rarr;</a>
      </div>
      <div class="card" style="text-align:center;padding:2rem">
        <h3 style="margin-bottom:0.75rem">Map Coverage</h3>
        <p style="color:var(--text-muted);margin-bottom:1.5rem">Download MeshMapper and help map real-world coverage in your area by wardriving the mesh.</p>
        <a href="https://github.com/MeshMapper/MeshMapper_Flutter_App" class="btn btn-primary" target="_blank" rel="noopener">Get MeshMapper &rarr;</a>
      </div>
    </div>
  </div>
</main>
