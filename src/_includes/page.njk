---
layout: base.njk
---
<main>
  <div class="page-wrap">
    <div class="page-header">
      <h1>{{ title }}</h1>
      {% if description %}<p class="page-subtitle">{{ description }}</p>{% endif %}
    </div>
    <article class="article-content">
      {{ content | safe }}
    </article>
  </div>
</main>
